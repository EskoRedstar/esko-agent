# Anthropic API anahtarı (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=

# İsteğe bağlı, varsayılan claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6

# Senkronizasyon anahtarı (esko-pwa'daki SYNC_KEY ile aynı olmalı)
ESKO_SYNC_KEY=ayda07

# Render Key Value (Redis) bağlantı URL'si
# Render → esko-kv → Connect → Internal Redis URL
REDIS_URL=
